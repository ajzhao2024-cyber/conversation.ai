# Server-only DeepSeek credential. Never expose this value in the browser.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Required in Vercel production. The function fails closed without these values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional. Comma-separated origins for an additional deployment or custom domain.
ALLOWED_ORIGINS=
