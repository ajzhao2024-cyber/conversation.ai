# Server-only OpenAI credential. Never expose this value in the browser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Required in Vercel production. The function fails closed without these values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional. Comma-separated origins for an additional deployment or custom domain.
ALLOWED_ORIGINS=
